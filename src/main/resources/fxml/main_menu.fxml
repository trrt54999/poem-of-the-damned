<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<StackPane fx:id="rootPane" styleClass="main-menu-root" xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.midnightdraft.poemofthedamned.presentation.controller.MainMenuController"
  prefHeight="400.0" prefWidth="600.0">
  <StackPane fx:id="mainMenuEnter">
    <VBox alignment="CENTER" spacing="10">
    <ImageView fx:id="companyLogo"/>
    <Button fx:id="loginButton" styleClass="login-button" text="%main_menu.login">
      <graphic>
        <ImageView fx:id="loginIcon"/>
      </graphic>
    </Button>
    </VBox>
  </StackPane>
</StackPane>
